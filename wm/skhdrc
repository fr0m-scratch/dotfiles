# skhd Configuration
# Generated by Yabai Config

# Apps / Spaces are handled by Karabiner:
# alt+1..9, alt+w, alt+l, alt+m, alt+r.
alt - d : yabai -m display --focus next
shift + alt - d : yabai -m window --display next --focus

# Focus
alt - 0x7B : yabai -m window --focus west
alt - 0x7D : yabai -m window --focus south
alt - 0x7E : yabai -m window --focus north
alt - 0x7C : yabai -m window --focus east

# Move
shift + alt - 0x7B : yabai -m window --swap west
shift + alt - 0x7D : yabai -m window --swap south
shift + alt - 0x7E : yabai -m window --swap north
shift + alt - 0x7C : yabai -m window --swap east

# Resize
ctrl + alt - 0x7B : yabai -m window --resize left:-20:0
ctrl + alt - 0x7D : yabai -m window --resize bottom:0:20
ctrl + alt - 0x7E : yabai -m window --resize top:0:-20
ctrl + alt - 0x7C : yabai -m window --resize right:20:0

# Layout
alt - e : yabai -m space --layout bsp
alt - s : yabai -m space --layout stack
alt - f : yabai -m window --toggle zoom-fullscreen
alt - t : yabai -m window --toggle float

# Moving arbitrary windows between Spaces needs the yabai scripting addition.

# >>> cockpit (mainDev) >>>
alt - 0x32 : /opt/homebrew/bin/tmux display-popup -E -t cockpit 2>/dev/null || open -a iTerm
cmd + alt - c : open -a iTerm
