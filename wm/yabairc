#!/usr/bin/env sh

# yabai configuration
# Generated by Yabai Config

# === Scripting Addition ===
# 需要 SIP 部分/完全关闭后才能加载(进 Recovery 执行 csrutil disable)。
# dock 重启后自动重载 SA;启动时加载一次。依赖 sudoers 免密条目(已存在)。
yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# === Window Rules (Exclusions) ===
yabai -m rule --add app="^yabai_config$" manage=off
yabai -m rule --add app="^System Preferences$" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Archive Utility$" manage=off
yabai -m rule --add app="^Finder$" title="(Copy|Move|Trash)" manage=off

# === Space Labels ===
yabai -m display 1 --label main
yabai -m display 2 --label side
yabai -m space 2 --label chat
yabai -m space 3 --label notion
yabai -m space 4 --label lark
yabai -m space 5 --label firefox
yabai -m space 7 --label side_space

# === App Placement ===
yabai -m rule --add label="app-wechat" app="^WeChat$" space=chat
yabai -m rule --add label="app-notion" app="^Notion$" space=notion
yabai -m rule --add label="app-lark" app="^Lark$" space=lark
yabai -m rule --add label="app-firefox" app="^Firefox$" space=firefox

# === Layout ===
yabai -m config layout bsp
yabai -m config window_placement second_child
yabai -m config auto_balance off
yabai -m config split_ratio 0.5
yabai -m config split_type auto

# === Gaps and Padding ===
yabai -m config window_gap 6
yabai -m config top_padding 6
yabai -m config bottom_padding 6
yabai -m config left_padding 6
yabai -m config right_padding 6

# === External Bar ===
yabai -m config external_bar all:0:0

# === Mouse ===
yabai -m config mouse_follows_focus on
yabai -m config focus_follows_mouse off
yabai -m config mouse_modifier alt
yabai -m config mouse_action1 move
yabai -m config mouse_action2 resize
yabai -m config mouse_drop_action swap

# === Window Appearance ===
yabai -m config window_opacity off
yabai -m config window_shadow on
yabai -m config window_animation_duration 0.0

echo "yabai configuration loaded..."
