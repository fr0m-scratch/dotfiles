# ─── Wave helpers: open files/artifacts in Wave blocks via wsh ────────────────
# wavep   <path|url>      → preview block      (files, images, dirs)
# waveweb [-m] <file|url> → web browser block  (HTML artifacts, localhost, urls)
#   -m = magnified.  Local paths are resolved to absolute file:// URLs.
wavep() {
  emulate -L zsh
  local mag=""
  [[ "$1" == "-m" || "$1" == "--magnified" ]] && { mag="-m"; shift; }
  local t="${1:-.}"
  if [[ "$t" != (http|https|file)://* ]]; then
    t="${t:A}"                                   # absolute, symlink-resolved
    [[ -e "$t" ]] || { print -u2 "wavep: no such path: $1"; return 1; }
  fi
  wsh view $mag "$t"
}
waveweb() {
  emulate -L zsh
  local mag=""
  [[ "$1" == "-m" || "$1" == "--magnified" ]] && { mag="-m"; shift; }
  local t="$1"
  [[ -n "$t" ]] || { print -u2 "usage: waveweb [-m] <file.html|url>"; return 2; }
  if [[ "$t" == (http|https|file)://* ]]; then
    wsh web open $mag "$t"
  elif [[ -e "$t" ]]; then
    local abs="${t:A}"
    wsh web open $mag "file://${abs// /%20}"     # encode spaces for file:// URL
  else
    print -u2 "waveweb: no such file: $t"; return 1
  fi
}
# ─────────────────────────────────────────────────────────────────────────────

# custom aliases
alias cl='clear'
alias check='history 0 | grep'

# Machine-local overrides (untracked): put secrets / per-machine tweaks here.
[[ -f ~/.zshrc.local ]] && source ~/.zshrc.local
