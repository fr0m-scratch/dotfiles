#!/usr/bin/env bash
set -euo pipefail
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin"

sleep 0.2
printf '%s wm_chat\n' "$(date '+%Y-%m-%d %H:%M:%S')" >> $HOME/.local/share/wm_app_shortcuts.log 2>/dev/null || true

yabai -m space --focus chat 2>/dev/null || true

open -a WeChat || true
open -a WeChat2 || true

while IFS= read -r id; do
  [ -n "$id" ] && yabai -m window --deminimize "$id" || true
done < <(yabai -m query --windows --space chat | jq -r '.[] | select(.app == "WeChat" and ."is-minimized" == true) | .id')

"$HOME/bin/wm_arrange_chat" || true
